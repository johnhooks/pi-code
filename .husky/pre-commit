#!/bin/sh

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)

if [ -z "$STAGED_FILES" ]; then
  echo "No staged files to lint."
  exit 0
fi

BIOME_FILES=""
MD_FILES=""

for file in $STAGED_FILES; do
  if [ -L "$file" ] || [ ! -f "$file" ]; then
    continue
  fi

  case "$file" in
    *.js|*.jsx|*.ts|*.tsx|*.json|*.jsonc)
      BIOME_FILES="$BIOME_FILES $file"
      ;;
    *.md)
      MD_FILES="$MD_FILES $file"
      ;;
  esac
done

if [ -n "$BIOME_FILES" ]; then
  echo "Running Biome on staged files..."
  npx biome check $BIOME_FILES
  if [ $? -ne 0 ]; then
    echo "Biome failed. Please fix the staged files before committing."
    exit 1
  fi
fi

if [ -n "$MD_FILES" ]; then
  echo "Running Prettier on staged markdown files..."
  npx prettier --check $MD_FILES
  if [ $? -ne 0 ]; then
    echo "Prettier failed. Please fix the staged markdown files before committing."
    exit 1
  fi
fi

echo "Staged file lint checks passed."
